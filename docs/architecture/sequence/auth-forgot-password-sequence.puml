@startuml Forgot Password - Sequence Diagram

actor Client
participant "UserController" as Controller
participant "UserService" as Service
participant "UserRepository" as UserRepo
participant "PasswordEncoder" as Encoder
database "Database" as DB

== Forgot Password Request ==
Client -> Controller : POST /api/users/forgetpass\n(ForgetPasswordRequest: email, password)
activate Controller

Controller -> Controller : @Valid ForgetPasswordRequest
note right: Bean Validation\n@Password on password field

Controller -> Service : forgetPassword(forgetPasswordRequest)
activate Service

Service -> UserRepo : findByEmail(forgetPasswordRequest.getEmail())
activate UserRepo
UserRepo -> DB : SELECT user by email
DB --> UserRepo : Optional<User>
UserRepo --> Service : Optional<User>
deactivate UserRepo

alt user not found (empty)
    Service --> Controller : throw AppException(USER_NOTEXISTED)
    Controller --> Client : 4xx ApiResponse (error)
else user found
    Service -> Encoder : encode(forgetPasswordRequest.getPassword())
    activate Encoder
    Encoder --> Service : encoded password
    deactivate Encoder

    Service -> Service : user.setPassword(encodedPassword)

    Service -> UserRepo : save(user)
    activate UserRepo
    UserRepo -> DB : UPDATE user (password)
    DB --> UserRepo : User
    UserRepo --> Service : User
    deactivate UserRepo

    Service -> Service : save(user) != null
    Service --> Controller : true
    deactivate Service

    Controller -> Controller : ApiResponse.setResult(true)

    Controller --> Client : 200 ApiResponse<Boolean>
    deactivate Controller
end

@enduml
