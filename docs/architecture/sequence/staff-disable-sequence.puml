@startuml Disable Staff - Sequence Diagram

actor "Restaurant Owner" as Owner
participant "StaffAccountController" as Controller
participant "StaffAccountService" as Service
participant "StaffAccountRepository" as StaffRepo
participant "StaffAccountMapper" as Mapper
database "Database" as DB

== Disable Staff Request ==
Owner -> Controller : DELETE /api/staff/{staffAccountId}
activate Controller

Controller -> Service : setStaffAccountStatus(staffAccountId)
activate Service

Service -> StaffRepo : findById(staffAccountId)
activate StaffRepo
StaffRepo -> DB : SELECT staff_account by id
DB --> StaffRepo : Optional<StaffAccount>
StaffRepo --> Service : Optional<StaffAccount>
deactivate StaffRepo

alt staff not found\nor staff already deleted
    Service --> Controller : throw AppException
    Controller --> Owner : 4xx ApiResponse (error)
else success
    Service -> Service : setStatus(INACTIVE)\n(toggle ACTIVE ↔ INACTIVE)

    Service -> StaffRepo : save(staffAccount)
    activate StaffRepo
    StaffRepo -> DB : UPDATE staff_account
    DB --> StaffRepo : StaffAccount
    StaffRepo --> Service : StaffAccount
    deactivate StaffRepo

    Service -> Mapper : toStaffAccountDTO(saved)
    activate Mapper
    Mapper --> Service : StaffAccountDTO
    deactivate Mapper

    Service --> Controller : StaffAccountDTO
    deactivate Service

    Controller -> Controller : ApiResponse.setResult(staffAccountDTO)

    Controller --> Owner : 200 ApiResponse<StaffAccountDTO>
    deactivate Controller
end

@enduml
